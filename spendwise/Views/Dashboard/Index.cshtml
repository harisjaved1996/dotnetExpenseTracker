@model spendwise.Models.DashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";
    var labelsJson = JsonSerializer.Serialize(Model.CategorySpend.Select(c => c.Category));
    var valuesJson = JsonSerializer.Serialize(Model.CategorySpend.Select(c => c.Amount));
    var colorsJson = JsonSerializer.Serialize(Model.CategorySpend.Select(c => c.Color));
}

<div class="sw-dashboard-wrapper">

    @* Desktop sidebar (hidden below lg) *@
    <nav class="sw-sidebar d-none d-lg-flex flex-column" aria-label="Main navigation">
        <span class="sw-sidebar-brand">SpendWise</span>
        <ul class="nav flex-column mt-2">
            <li class="nav-item">
                <a class="nav-link active" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">
                    <i class="bi bi-receipt"></i> Expenses
                </a>
            </li>
        </ul>
    </nav>

    @* Mobile offcanvas sidebar *@
    <div class="offcanvas offcanvas-start sw-sidebar"
         tabindex="-1"
         id="mobileSidebar"
         aria-labelledby="mobileSidebarLabel">
        <div class="offcanvas-header p-0" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
            <span class="sw-sidebar-brand flex-grow-1" id="mobileSidebarLabel">SpendWise</span>
            <button type="button"
                    class="btn-close btn-close-white me-3"
                    data-bs-dismiss="offcanvas"
                    aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <ul class="nav flex-column mt-2">
                <li class="nav-item">
                    <a class="nav-link active" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-receipt"></i> Expenses
                    </a>
                </li>
            </ul>
        </div>
    </div>

    @* Main content *@
    <div class="sw-main-content">

        @* Top bar *@
        <div class="sw-topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-link text-dark p-0 d-lg-none"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#mobileSidebar"
                        aria-controls="mobileSidebar"
                        aria-label="Open navigation">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <span class="fw-semibold" style="color: var(--sw-navy);">Dashboard</span>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="sw-avatar">AM</span>
                <span class="fw-medium d-none d-sm-inline" style="color: var(--sw-navy);">Alex Morgan</span>
                <a href="#" class="sw-btn-outline" style="padding: 5px 14px; font-size: 0.85rem;">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </a>
            </div>
        </div>

        @* Page content *@
        <div class="p-4">

            @* Welcome header *@
            <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between mb-4 gap-2">
                <p class="mb-0 text-muted">Welcome back, <strong>Alex Morgan</strong></p>
                <span class="text-muted small">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</span>
            </div>

            @* Stat cards *@
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4 mb-4">
                <div class="col">
                    <div class="sw-stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted small mb-1">Spent This Month</p>
                                <h4 class="fw-bold mb-0" style="color: var(--sw-navy);">
                                    @Model.TotalSpentThisMonth.ToString("C")
                                </h4>
                            </div>
                            <i class="bi bi-wallet2 fs-1" style="color: var(--sw-gold);"></i>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="sw-stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted small mb-1">Monthly Budget</p>
                                <h4 class="fw-bold mb-0" style="color: var(--sw-navy);">
                                    @Model.MonthlyBudget.ToString("C")
                                </h4>
                            </div>
                            <i class="bi bi-piggy-bank fs-1" style="color: var(--sw-gold);"></i>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="sw-stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted small mb-1">Saved This Month</p>
                                <h4 class="fw-bold mb-0" style="color: var(--sw-navy);">
                                    @Model.TotalSavingsThisMonth.ToString("C")
                                </h4>
                            </div>
                            <i class="bi bi-arrow-up-circle fs-1" style="color: var(--sw-gold);"></i>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="sw-stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted small mb-1">Transactions</p>
                                <h4 class="fw-bold mb-0" style="color: var(--sw-navy);">
                                    @Model.TotalExpensesThisMonth
                                </h4>
                            </div>
                            <i class="bi bi-list-check fs-1" style="color: var(--sw-gold);"></i>
                        </div>
                    </div>
                </div>
            </div>

            @* Chart + Quick Actions *@
            <div class="row g-4 mb-4">
                <div class="col-lg-7">
                    <div class="sw-dashboard-card">
                        <h6 class="fw-semibold mb-3" style="color: var(--sw-navy);">Spending by Category</h6>
                        <canvas id="categoryChart"
                                data-labels="@labelsJson"
                                data-values="@valuesJson"
                                data-colors="@colorsJson"
                                style="max-height: 280px;">
                        </canvas>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="sw-dashboard-card d-flex flex-column gap-3">
                        <h6 class="fw-semibold mb-1" style="color: var(--sw-navy);">Quick Actions</h6>
                        <a href="#" class="sw-btn-gold text-center">
                            <i class="bi bi-plus-lg me-1"></i>Add Expense
                        </a>
                        <a href="#" class="sw-btn-outline text-center">View All Expenses</a>
                        <a href="#" class="sw-btn-outline text-center">Manage Categories</a>
                        <a href="#" class="sw-btn-outline text-center">
                            <i class="bi bi-download me-1"></i>Download Report
                        </a>
                        <div class="mt-1">
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Budget Used</span>
                                <span>@Model.BudgetUsedPercent%</span>
                            </div>
                            <div class="progress" style="height: 10px; border-radius: 6px;">
                                <div class="progress-bar"
                                     role="progressbar"
                                     style="width: @(Model.BudgetUsedPercent)%; background-color: var(--sw-gold);"
                                     aria-valuenow="@Model.BudgetUsedPercent"
                                     aria-valuemin="0"
                                     aria-valuemax="100">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Recent Expenses table *@
            <div class="sw-dashboard-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-semibold mb-0" style="color: var(--sw-navy);">Recent Expenses</h6>
                    <a href="#" class="small fw-medium" style="color: var(--sw-gold); text-decoration: none;">
                        View All &rarr;
                    </a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead style="background-color: var(--sw-navy); color: #fff;">
                            <tr>
                                <th class="fw-normal py-3">#</th>
                                <th class="fw-normal py-3">Description</th>
                                <th class="fw-normal py-3">Category</th>
                                <th class="fw-normal py-3">Date</th>
                                <th class="fw-normal py-3 text-end">Amount</th>
                                <th class="fw-normal py-3">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rowNum = 1; }
                            @foreach (var expense in Model.RecentExpenses)
                            {
                                <tr>
                                    <td class="text-muted small">@rowNum</td>
                                    <td class="fw-medium">@expense.Description</td>
                                    <td class="text-muted small">@expense.Category</td>
                                    <td class="text-muted small">@expense.Date.ToString("MMM d, yyyy")</td>
                                    <td class="text-end fw-medium">@expense.Amount.ToString("C")</td>
                                    <td>
                                        @if (expense.Status == "Paid")
                                        {
                                            <span class="badge bg-success">Paid</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                    </td>
                                </tr>
                                rowNum++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
}
