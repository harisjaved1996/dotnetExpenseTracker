<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SpendWise</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/spendwise.styles.css" asp-append-version="true" />
</head>
<body>

    @if (Context.Session.GetString("AuthUser") == null)
    {
        <header>
            <nav class="navbar navbar-expand-md navbar-dark sw-navbar fixed-top">
                <div class="container">
                    <a class="navbar-brand sw-brand" asp-controller="Home" asp-action="Index">SpendWise</a>
                    <button class="navbar-toggler border-0" type="button"
                            data-bs-toggle="collapse" data-bs-target="#navbarMain"
                            aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarMain">
                        <div class="ms-auto d-flex align-items-center gap-2 py-2 py-md-0">
                            <a asp-controller="Account" asp-action="Login" class="sw-btn-outline">Login</a>
                            <a asp-controller="Account" asp-action="Register" class="sw-btn-gold">Register</a>
                        </div>
                    </div>
                </div>
            </nav>
        </header>
    }

    <main role="main">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container mt-5">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="sw-footer">
        <div class="container">
            <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-2">
                <span>&copy; 2026 SpendWise. All rights reserved.</span>
                @if (Context.Session.GetString("AuthUser") == null)
                {
                    <div>
                        <a asp-controller="Home" asp-action="TermsAndConditions" class="sw-footer-link">Terms &amp; Conditions</a>
                        <span class="sw-footer-sep">|</span>
                        <a asp-controller="Home" asp-action="PrivacyPolicy" class="sw-footer-link">Privacy Policy</a>
                    </div>
                }
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
