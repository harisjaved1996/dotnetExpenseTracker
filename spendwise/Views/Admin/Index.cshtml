@model spendwise.Models.AdminDashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Admin Dashboard";
    var labelsJson = JsonSerializer.Serialize(Model.CategorySpend.Select(c => c.Category));
    var valuesJson = JsonSerializer.Serialize(Model.CategorySpend.Select(c => c.Amount));
    var colorsJson = JsonSerializer.Serialize(Model.CategorySpend.Select(c => c.Color));
}

<div class="sw-dashboard-wrapper">

    @* Desktop sidebar (hidden below lg) *@
    <nav class="sw-sidebar d-none d-lg-flex flex-column" aria-label="Admin navigation">
        <span class="sw-sidebar-brand">SpendWise Admin</span>
        <ul class="nav flex-column mt-2">
            <li class="nav-item">
                <a class="nav-link active" asp-controller="Admin" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">
                    <i class="bi bi-people"></i> Users
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">
                    <i class="bi bi-tags"></i> Categories
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">
                    <i class="bi bi-receipt"></i> Expenses
                </a>
            </li>
        </ul>
    </nav>

    @* Mobile offcanvas sidebar *@
    <div class="offcanvas offcanvas-start sw-sidebar"
         tabindex="-1"
         id="adminMobileSidebar"
         aria-labelledby="adminMobileSidebarLabel">
        <div class="offcanvas-header p-0" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
            <span class="sw-sidebar-brand flex-grow-1" id="adminMobileSidebarLabel">SpendWise Admin</span>
            <button type="button"
                    class="btn-close btn-close-white me-3"
                    data-bs-dismiss="offcanvas"
                    aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <ul class="nav flex-column mt-2">
                <li class="nav-item">
                    <a class="nav-link active" asp-controller="Admin" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-people"></i> Users
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-tags"></i> Categories
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-receipt"></i> Expenses
                    </a>
                </li>
            </ul>
        </div>
    </div>

    @* Main content *@
    <div class="sw-main-content">

        @* Top bar *@
        <div class="sw-topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-link text-dark p-0 d-lg-none"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#adminMobileSidebar"
                        aria-controls="adminMobileSidebar"
                        aria-label="Open navigation">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <span class="fw-semibold" style="color: var(--sw-navy);">Admin Dashboard</span>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="sw-avatar">SA</span>
                <span class="fw-medium d-none d-sm-inline" style="color: var(--sw-navy);">Super Admin</span>
                <span class="badge bg-danger d-none d-sm-inline">Admin</span>
                <a href="#" class="sw-btn-outline" style="padding: 5px 14px; font-size: 0.85rem;">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </a>
            </div>
        </div>

        @* Page content *@
        <div class="p-4">

            @* Welcome header *@
            <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between mb-4 gap-2">
                <div>
                    <h5 class="fw-semibold mb-1" style="color: var(--sw-navy);">System Overview</h5>
                    <p class="text-muted mb-0 small">SpendWise Administration Panel</p>
                </div>
                <span class="text-muted small">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</span>
            </div>

            @* Stat cards *@
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4 mb-4">
                <div class="col">
                    <div class="sw-stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted small mb-1">Registered Users</p>
                                <h4 class="fw-bold mb-0" style="color: var(--sw-navy);">@Model.TotalUsers</h4>
                            </div>
                            <i class="bi bi-people-fill fs-1" style="color: var(--sw-gold);"></i>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="sw-stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted small mb-1">Total Expenses</p>
                                <h4 class="fw-bold mb-0" style="color: var(--sw-navy);">@Model.TotalExpenses</h4>
                            </div>
                            <i class="bi bi-receipt-cutoff fs-1" style="color: var(--sw-gold);"></i>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="sw-stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted small mb-1">Categories</p>
                                <h4 class="fw-bold mb-0" style="color: var(--sw-navy);">@Model.CategoryCount</h4>
                            </div>
                            <i class="bi bi-tags-fill fs-1" style="color: var(--sw-gold);"></i>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="sw-stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="text-muted small mb-1">Monthly Volume</p>
                                <h4 class="fw-bold mb-0" style="color: var(--sw-navy);">@Model.MonthlyVolume.ToString("C")</h4>
                            </div>
                            <i class="bi bi-currency-dollar fs-1" style="color: var(--sw-gold);"></i>
                        </div>
                    </div>
                </div>
            </div>

            @* Chart + Admin Actions *@
            <div class="row g-4 mb-4">
                <div class="col-lg-7">
                    <div class="sw-dashboard-card">
                        <h6 class="fw-semibold mb-3" style="color: var(--sw-navy);">Expense Distribution</h6>
                        <canvas id="categoryChart"
                                data-labels="@labelsJson"
                                data-values="@valuesJson"
                                data-colors="@colorsJson"
                                style="max-height: 280px;">
                        </canvas>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="sw-dashboard-card d-flex flex-column gap-3">
                        <h6 class="fw-semibold mb-1" style="color: var(--sw-navy);">Admin Actions</h6>
                        <a href="#" class="sw-btn-gold text-center">
                            <i class="bi bi-plus-lg me-1"></i>Add Category
                        </a>
                        <a href="#" class="sw-btn-outline text-center">Manage Users</a>
                        <a href="#" class="sw-btn-outline text-center">View All Expenses</a>
                        <a href="#" class="sw-btn-outline text-center">
                            <i class="bi bi-download me-1"></i>Export Report
                        </a>

                        @* System health strip *@
                        <div class="mt-1 pt-2" style="border-top: 1px solid #e5e7eb;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="small fw-medium" style="color: var(--sw-navy);">System Status</span>
                                <span class="small text-success fw-medium">
                                    <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Operational
                                </span>
                            </div>
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Database</span>
                                <span class="text-success"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Connected</span>
                            </div>
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Last Backup</span>
                                <span>Yesterday at 2:00 AM</span>
                            </div>
                            <div class="d-flex justify-content-between small text-muted">
                                <span>Uptime</span>
                                <span>99.8%</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Recent Users table *@
            <div class="sw-dashboard-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-semibold mb-0" style="color: var(--sw-navy);">Recent Users</h6>
                    <a href="#" class="small fw-medium" style="color: var(--sw-gold); text-decoration: none;">
                        View All &rarr;
                    </a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead style="background-color: var(--sw-navy); color: #fff;">
                            <tr>
                                <th class="fw-normal py-3">#</th>
                                <th class="fw-normal py-3">Name</th>
                                <th class="fw-normal py-3">Email</th>
                                <th class="fw-normal py-3">Role</th>
                                <th class="fw-normal py-3">Joined</th>
                                <th class="fw-normal py-3">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rowNum = 1; }
                            @foreach (var user in Model.RecentUsers)
                            {
                                <tr>
                                    <td class="text-muted small">@rowNum</td>
                                    <td class="fw-medium">@user.Name</td>
                                    <td class="text-muted small">@user.Email</td>
                                    <td>
                                        @if (user.Role == "Admin")
                                        {
                                            <span class="badge" style="background-color: var(--sw-navy);">Admin</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">User</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@user.JoinedAt.ToString("MMM d, yyyy")</td>
                                    <td>
                                        @if (user.Status == "Active")
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Suspended</span>
                                        }
                                    </td>
                                </tr>
                                rowNum++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
}
