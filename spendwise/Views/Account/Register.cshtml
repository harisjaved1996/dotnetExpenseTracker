@model spendwise.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="sw-auth-banner">
    <h1 class="fw-bold fs-2">Create Your Account</h1>
    <p class="mb-0 opacity-75">Start tracking your expenses with SpendWise</p>
</div>

<div class="container">
    <div class="sw-auth-card">
        <div class="text-center mb-4">
            <span class="fw-bold fs-4" style="color: var(--sw-navy);">SpendWise</span>
        </div>

        <div class="sw-role-toggle mb-4" role="group">
            <button type="button" class="sw-role-btn active" data-role="User">User</button>
            <button type="button" class="sw-role-btn" data-role="Admin">Admin</button>
        </div>

        <form asp-action="Register" method="post">
            <input type="hidden" asp-for="Role" />
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-medium"></label>
                <input asp-for="FullName" class="form-control" type="text" placeholder="Jane Smith" autocomplete="name" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-medium"></label>
                <input asp-for="Email" class="form-control" type="email" placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-1">
                <label asp-for="Password" class="form-label fw-medium"></label>
                <div class="input-group">
                    <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" autocomplete="new-password" />
                    <button class="sw-pw-toggle px-3" type="button" tabindex="-1" aria-label="Toggle password visibility">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <div class="d-flex align-items-center gap-2 mt-2">
                    <div class="progress flex-grow-1" style="height: 5px;">
                        <div id="sw-pw-strength-bar" class="progress-bar" role="progressbar" style="width: 0%; transition: width .3s, background-color .3s;"></div>
                    </div>
                    <span id="sw-pw-strength-label" class="small fw-medium" style="min-width: 44px; color: var(--sw-navy);"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label fw-medium"></label>
                <div class="input-group">
                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••••" autocomplete="new-password" />
                    <button class="sw-pw-toggle px-3" type="button" tabindex="-1" aria-label="Toggle confirm password visibility">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="AgreeToTerms" class="form-check-input" type="checkbox" />
                <label class="form-check-label small">
                    I agree to the
                    <a asp-controller="Home" asp-action="TermsAndConditions" target="_blank" style="color: var(--sw-gold); font-weight: 600;">Terms &amp; Conditions</a>
                    and
                    <a asp-controller="Home" asp-action="PrivacyPolicy" target="_blank" style="color: var(--sw-gold); font-weight: 600;">Privacy Policy</a>
                </label>
                <span asp-validation-for="AgreeToTerms" class="text-danger small d-block"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <button type="submit" class="btn w-100 fw-semibold mb-3" style="background-color: var(--sw-gold); color: #fff; padding: .65rem;">
                Create Account
            </button>
        </form>

        <hr class="my-3" />

        <p class="text-center mb-0 small">
            Already have an account?
            <a asp-controller="Account" asp-action="Login" style="color: var(--sw-gold); font-weight: 600;">Sign In</a>
        </p>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
